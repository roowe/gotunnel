#!/bin/sh /etc/rc.common
# /etc/init.d/gotunnel
# Init script for gotunnel (OpenWrt / iStoreOS)
# - Uses procd when available (recommended)
# - Falls back to start-stop-daemon or plain backgrounding when procd is not available
# - Reads configuration from /etc/config/gotunnel (UCI)
# - Writes pidfile to /var/run/gotunnel.pid and fallback log to /var/log/gotunnel.log

START=99
STOP=10
USE_PROCD=1

# Path to the gotunnel binary (override in script or via UCI user setting)
GOTUNNEL_BIN="/usr/bin/gotunnel"
PIDFILE="/var/run/gotunnel.pid"
LOGFILE="/var/log/gotunnel.log"
CONFIG_SECTION="gotunnel"

. /lib/functions.sh 2>/dev/null || true
. /lib/functions/service.sh 2>/dev/null || true

# Prefer IPKG_INSTROOT copies of helper libs when available
if [ -n "$IPKG_INSTROOT" ]; then
    . $IPKG_INSTROOT/lib/functions.sh 2>/dev/null || true
    . $IPKG_INSTROOT/lib/functions/service.sh 2>/dev/null || true
fi

get_config() {
    # read a value from UCI; fallback to provided default
    # usage: get_config key default
    local key="$1"; shift
    local def="$1"; shift
    local val
    val=$(uci get ${CONFIG_SECTION}.@${CONFIG_SECTION}[0].${key} 2>/dev/null || echo "")
    [ -n "$val" ] && echo "$val" || echo "$def"
}

_build_cmd() {
    # construct the command line to run gotunnel
    listen="$(get_config listen ':8001')"
    backend="$(get_config backend '127.0.0.1:3128')"
    secret="$(get_config secret 'the answer to life, the universe and everything')"
    tunnels="$(get_config tunnels 0)"
    loglevel="$(get_config log 1)"
    echo "${GOTUNNEL_BIN} -listen=${listen} -backend=${backend} -secret='${secret}' -tunnels=${tunnels} -log=${loglevel}"
}

start_service() {
    enabled="$(uci get ${CONFIG_SECTION}.@${CONFIG_SECTION}[0].enabled 2>/dev/null || echo 1)"
    [ "$enabled" = "1" ] || return 0

    cmd="$(_build_cmd)"

    # If procd functions available use them (preferred)
    if command -v procd_open_instance >/dev/null 2>&1; then
        procd_open_instance
        # optional user to run as (from UCI)
        user="$(get_config user '')"
        [ -n "$user" ] && procd_set_param user "$user"
        # run via shell so quoting works
        procd_set_param command /bin/sh -c "$cmd"
        # send stdout/stderr to logread
        procd_set_param stdout 1
        procd_set_param stderr 1
        # auto-restart on exit
        procd_set_param respawn
        procd_close_instance
        return 0
    fi

    # Fallback: use start-stop-daemon if available (supports both Debian and BusyBox variants)
    if [ -x /sbin/start-stop-daemon ]; then
        SSDD=/sbin/start-stop-daemon
        if "$SSDD" --help 2>/dev/null | grep -q -- '--start'; then
            "$SSDD" --start --background --make-pidfile --pidfile "${PIDFILE}" \
                --exec /bin/sh -- -c "exec ${cmd} > ${LOGFILE} 2>&1"
        else
            # BusyBox style: -S start, -x executable, -p pidfile, -m write pidfile, -b background
            "$SSDD" -S -x /bin/sh -- -c "exec ${cmd} > ${LOGFILE} 2>&1" -p "${PIDFILE}" -m -b
        fi
        return 0
    fi

    # Last fallback: simple background, write pidfile
    /bin/sh -c "exec ${cmd} > ${LOGFILE} 2>&1 & echo \$! > ${PIDFILE}"
}

stop_service() {
    # Try start-stop-daemon stop via pidfile, then by name
    if [ -x /sbin/start-stop-daemon ]; then
        SSDD=/sbin/start-stop-daemon
        if "$SSDD" --help 2>/dev/null | grep -q -- '--stop'; then
            if [ -f "${PIDFILE}" ]; then
                "$SSDD" --stop --pidfile "${PIDFILE}" --retry TERM/5/KILL/5 || true
                rm -f "${PIDFILE}"
                return 0
            fi
            "$SSDD" --stop --name "$(basename ${GOTUNNEL_BIN})" --retry TERM/5/KILL/5 || true
            rm -f "${PIDFILE}"
            return 0
        else
            # BusyBox style: -K stop, -p pidfile, -n name, -s signal
            if [ -f "${PIDFILE}" ]; then
                "$SSDD" -K -p "${PIDFILE}" -s TERM || true
                rm -f "${PIDFILE}"
                return 0
            fi
            "$SSDD" -K -n "$(basename ${GOTUNNEL_BIN})" -s TERM || true
            rm -f "${PIDFILE}"
            return 0
        fi
    fi

    # Fallback: pidof + kill
    if command -v pidof >/dev/null 2>&1; then
        for pid in $(pidof "$(basename ${GOTUNNEL_BIN})"); do
            kill "$pid" 2>/dev/null || true
        done
    else
        # try pkill if available
        if command -v pkill >/dev/null 2>&1; then
            pkill -f "${GOTUNNEL_BIN}" 2>/dev/null || true
        fi
    fi
    rm -f "${PIDFILE}"
    return 0
}

restart_service() {
    stop_service
    start_service
}

# Optional: status/running helpers for compatibility
service_running() {
    if command -v pidof >/dev/null 2>&1; then
        pidof "$(basename ${GOTUNNEL_BIN})" >/dev/null 2>&1
        return $?
    fi
    # try checking pidfile
    [ -f "${PIDFILE}" ] && kill -0 "$(cat ${PIDFILE})" >/dev/null 2>&1
    return $?
}

# Optional: make procd helpers available from IPKG_INSTROOT if present
[ -n "$USE_PROCD" ] && {
    if [ -n "$IPKG_INSTROOT" ] && [ -f "$IPKG_INSTROOT/lib/functions/procd.sh" ]; then
        . "$IPKG_INSTROOT/lib/functions/procd.sh" 2>/dev/null || true
    else
        . /lib/functions/procd.sh 2>/dev/null || true
    fi
}

extra_command "start" "Start the service"
extra_command "stop" "Stop the service"
extra_command "restart" "Restart the service"
extra_command "reload" "Reload configuration files (or restart if service does not implement reload)"
extra_command "enable" "Enable service autostart"
extra_command "disable" "Disable service autostart"
extra_command "enabled" "Check if service is started on boot"